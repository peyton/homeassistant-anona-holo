#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
GLOBAL_MISE_CONFIG_PATH="${HOME}/.config/mise"
CACHE_ROOT="${TMPDIR:-/tmp}/codex-homeassistant-anona-holo"

append_path_env() {
    local var_name="$1"
    local path="$2"
    local current_value="${!var_name:-}"

    case ":${current_value}:" in
        *":${path}:"*) ;;
        "::")
            export "${var_name}=${path}"
            ;;
        *)
            export "${var_name}=${current_value}:${path}"
            ;;
    esac
}

append_path_env MISE_IGNORED_CONFIG_PATHS "${GLOBAL_MISE_CONFIG_PATH}"
append_path_env MISE_TRUSTED_CONFIG_PATHS "${ROOT_DIR}"

export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${CACHE_ROOT}/xdg-cache}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-${CACHE_ROOT}/uv-cache}"
export UV_TOOL_DIR="${UV_TOOL_DIR:-${CACHE_ROOT}/uv-tools}"

cd "${ROOT_DIR}"

case "${1:-}" in
    setup)
        exec ./scripts/setup
        ;;
    develop)
        exec mise exec -- just develop
        ;;
    check)
        exec mise exec -- just check
        ;;
    *)
        echo "usage: $0 {setup|develop|check}" >&2
        exit 2
        ;;
esac
