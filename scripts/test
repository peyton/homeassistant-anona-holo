#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

PYRIGHT_PACKAGE="${PYRIGHT_PACKAGE:-pyright==1.1.408}"

XDG_CACHE_HOME="${XDG_CACHE_HOME:-/tmp/xdg-cache}" \
UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache}" \
UV_TOOL_DIR="${UV_TOOL_DIR:-/tmp/uv-tools}" \
uvx --from "${PYRIGHT_PACKAGE}" pyright --pythonpath ./.venv/bin/python custom_components/anona_security tests

.venv/bin/python -m pytest -q
