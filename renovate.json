{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": true,
  "automergeType": "pr",
  "dependencyDashboard": false,
  "dependencyDashboardAutoclose": true,
  "rebaseWhen": "behind-base-branch",
  "minimumReleaseAge": "3 days",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 3,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions",
        "mise",
        "pip_requirements"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchManagers": [
        "pip_requirements"
      ],
      "matchDepNames": [
        "homeassistant"
      ],
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
